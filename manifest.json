{
  "manifest_version": 3,
  "name": "Scraper de Vagas (Lotes Seguros)",
  "version": "1.0.5",
  "description": "Coleta em lotes e baixa CSV automaticamente.",
  "permissions": ["scripting", "storage", "activeTab", "downloads"],
  "host_permissions": ["https://seasonaljobs.dol.gov/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Scraper de Vagas",
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
